root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab
indent_size = tab
tab_width = 8

[go.mod]
indent_style = tab
indent_size = tab
tab_width = 8

[go.sum]
indent_style = tab
indent_size = tab
tab_width = 8

[Makefile]
indent_style = tab
indent_size = tab
tab_width = 8

[*.{sh,bash}]
indent_style = space
indent_size = 2

[*.{md,markdown}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 100

[*.{el,scm,lisp,zy}]
indent_style = space
indent_size = 2

[*.{yaml,yml,json,toml}]
indent_style = space
indent_size = 2
